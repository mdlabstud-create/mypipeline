# Copy to `.env` and fill in values. Never commit `.env`.

# --- Required ---
DATABASE_URL=postgresql://user:password@localhost:5432/dropship
REDIS_URL=redis://localhost:6379

# Scraping
APIFY_API_TOKEN=
SCRAPINGDOG_API_KEY=

# Proxy (required by env schema — used for legacy Playwright scraping)
WEBSHARE_PROXY_SERVER=your-proxy-host:port
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# AliExpress Open Platform
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=default

# AI content
OPENAI_API_KEY=

# Images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Shopify
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
# OAuth (only needed for embedded/public app installs)
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# Currency
EXCHANGE_RATE_API_KEY=

# --- Pipeline behaviour ---
PIPELINE_ENABLED=true
AUTO_PUBLISH=false
MERGER_MAX_RESEARCH_PER_RUN=10
LISTING_MIN_IMAGES=5
MARKUP_MULTIPLIER=2.8
MIN_MARGIN_PCT=10
STORE_VS_AMAZON_RATIO=0.9
NODE_ENV=development
PORT=3000

# Public HTTPS URL (required for Shopify/AliExpress OAuth callbacks)
PUBLIC_URL=

# API auth — set a strong random string; leave blank for open dev mode
API_BEARER_TOKEN=

# --- Optional notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
REAUTH_NOTIFY_EMAIL=
REAUTH_EMAIL_FROM=

# --- Optional feature flags ---
# ALLOW_AMAZON_AS_SUPPLIER=false
# DROPSHIP_AUTO_FORWARD=false
# DROPSHIP_FORWARD_DRY_RUN=true
# DISABLE_RESEARCHER_KILL_SWITCH=false
# DEMO_MODE=false
# SENTRY_DSN=
