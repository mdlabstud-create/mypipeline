{
  "name": "dropship-pipeline",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "doctor": "tsx src/scripts/doctor.ts",
    "autorun": "tsx src/scripts/auto-run.ts",
    "finalize:publish": "tsx src/scripts/finalize-publish.ts",
    "shopify:set-prices": "tsx src/scripts/shopify-set-prices.ts",
    "shopify:repair-missing": "tsx src/scripts/repair-missing-shopify-products.ts",
    "recompute:prices": "tsx src/scripts/recompute-listing-prices.ts",
    "export:channel-prices": "tsx src/scripts/export-channel-prices.ts",
    "test:aliexpress": "tsx src/scripts/test-aliexpress-batch.ts",
    "dashboard:dev": "npm --prefix src/dashboard run dev",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/migrations/migrate.ts",
    "start": "tsx src/index.ts",
    "lint": "eslint .",
    "format": "prettier -w .",
    "test": "vitest run",
    "test:integration": "cross-env RUN_INTEGRATION=1 vitest run",
    "test:full": "cross-env RUN_INTEGRATION=1 npm run migrate && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "apify-client": "^2.23.1",
    "@bull-board/api": "^6.12.7",
    "@bull-board/express": "^6.12.7",
    "@sentry/node": "^9.46.0",
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.12.2",
    "bullmq": "^5.58.3",
    "cloudinary": "^2.7.0",
    "compromise": "^14.14.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "natural": "^8.1.0",
    "node-cron": "^4.2.1",
    "openai": "^5.15.0",
    "pg": "^8.16.3",
    "playwright": "^1.55.0",
    "winston": "^3.18.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.2.2",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}